{
  "name": "@agents/visual-artifact-cli",
  "version": "0.3.3",
  "description": "Fast self-contained CLI for creating and serving visual artifacts.",
  "type": "module",
  "bin": {
    "visual-artifact": "./dist/visual-artifact"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "clean": "rm -rf dist node_modules src/assets/contract.json && rm -f .*.bun-build",
    "install:binary": "bun run scripts/install.ts",
    "release": "bun run scripts/release.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@agents/visual-artifact-annotations": "file:../shared",
    "@aws-sdk/client-s3": "^3.1080.0",
    "commander": "^12.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
