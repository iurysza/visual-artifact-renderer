#!/usr/bin/env bash
# Check whether the visualizer renderer server is running.
# Usage: vaz-status
source "${VAZ_SKILL_DIR:-$HOME/.pi/skills/visual-artifact}/lib/common.sh"

if server_running; then
  echo "{\"running\": true, \"url\": \"$VAZ_SERVER_URL\"}"
  exit 0
else
  echo "{\"running\": false, \"url\": \"$VAZ_SERVER_URL\"}"
  exit 1
fi
