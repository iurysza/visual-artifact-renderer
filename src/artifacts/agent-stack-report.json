    "riskLedger": [
      {
        "risk": "Secret leakage",
        "severity": "high",
        "mitigation": "Local secrets.env, chmod 600, runtime injectors, read/list/shell blocks",
        "residual": "Shells and third-party tools still need disciplined usage"
      },
      {
        "risk": "MCP drift",
        "severity": "medium",
        "mitigation": "Strict manifests and --check command",
        "residual": "Server installs can drift outside repo"
      },
      {
        "risk": "Wrapper drift",
        "severity": "medium",
        "mitigation": "service.sh doctor probes launchd, HTTP, HTTPS, reports",
        "residual": "Tailscale and port listeners remain environmental"
      },
      {
        "risk": "Artifact convention split",
        "severity": "low",
        "mitigation": "Document ai-artifacts vs .ai-artifacts",
        "residual": "Pick one convention later if shared maps matter"
      },
      {
        "risk": "Tool context cost",
        "severity": "medium",
        "mitigation": "context-audit and disabled expensive tool families",
        "residual": "New packages/MCP servers need re-audit"
