        "area": "agents/",
        "installed_to": "~/.agents",
        "owns": "Shared rules, commands, personas, and 49 skills",
        "boundary": "Reusable behavior only"
      },
      {
        "area": "pi/agent/",
        "installed_to": "~/.pi/agent",
        "owns": "Pi settings, prompts, themes, permissions, keybindings, extensions",
        "boundary": "Runtime sessions and caches stay local"
      },
      {
        "area": "opencode/",
        "installed_to": "~/.config/opencode",
        "owns": "Templates, plugins, agents, commands, TUI config, package metadata",
        "boundary": "Rendered config, not volatile state"
      },
      {
        "area": "mcpx-manifests/",
        "installed_to": "~/.config/mcpx",
        "owns": "Strict JSON manifests and required secret names",
        "boundary": "No server repos, OAuth, cookies, or secret values"
      },
      {
        "area": "templates/",
        "installed_to": "~/.config/ai",
        "owns": "Example auth, web-search, and secret env files",
        "boundary": "Copied only if missing; chmod 600"
      },
      {
        "area": "opencode-web-wrapper",
        "installed_to": "~/.local/share/opencode-web-wrapper",
        "owns": "launchd service, Tailscale Serve route, reports sidecar",
        "boundary": "Optional wrapper; does not replace the CLI"
      }
    ],
    "flowEdges": [
      {
        "from": "agents repo",
        "to": "~/.agents",
        "mode": "link",
        "purpose": "Expose shared skills, commands, rules, and personas"
      },
      {
        "from": "pi/agent",
        "to": "~/.pi/agent",
        "mode": "link",
        "purpose": "Load Pi settings, extensions, prompts, themes"
      },
      {
        "from": "opencode/",
        "to": "~/.config/opencode",
        "mode": "render + link",
        "purpose": "Build OpenCode config, agents, plugins, MCP"
      },
      {
        "from": "secrets.env",
        "to": "Pi + OpenCode runtime",
        "mode": "inject",
        "purpose": "Provide credentials without exposing paths or values"
      },
      {
        "from": "bare opencode",
        "to": "opencode web",
        "mode": "attach",
        "purpose": "Open web session in current project with --dir \"$PWD\""
      },
      {
        "from": "reports-server.py",
        "to": "/reports/",
        "mode": "serve",
        "purpose": "Expose generated HTML reports through a sidecar"
      }
    ],
    "opencodeAreas": [
      {
        "area": "CLI ownership",
        "configured": "~/.local/bin/opencode -> ~/.opencode/bin/opencode",
        "why": "Standalone CLI works without Desktop; Desktop is fallback only"
