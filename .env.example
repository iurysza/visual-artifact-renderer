# Visual artifact Cloudflare publishing secrets.
# Copy this file to `.env` and fill in real values from Cloudflare R2.
# `.env` is gitignored; never commit it.

VISUAL_ARTIFACT_CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
VISUAL_ARTIFACT_CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key

# R2 bucket used for publishing. The default for this repo is visual-artifact-renderer.
# If you create your own bucket, change this value AND run `visual-artifact setup cloudflare`
# so worker/wrangler.jsonc is updated to match.
VISUAL_ARTIFACT_CLOUDFLARE_R2_BUCKET=visual-artifact-renderer
