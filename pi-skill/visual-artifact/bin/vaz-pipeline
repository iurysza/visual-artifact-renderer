#!/usr/bin/env bash
# Run the full visual-artifact pipeline against any repository.
# Usage: vaz-pipeline <repoRoot> [slug]
set -e
source "${VAZ_SKILL_DIR:-$HOME/.pi/skills/visual-artifact}/lib/common.sh"

repo_root="${1:-$(pwd)}"
repo_root="$(cd "$repo_root" && pwd)"
slug="${2:-$(basename "$repo_root")}"

ensure_runtime
ensure_server

cd "$VAZ_DIR"

# Run the pipeline. Output is written to <repoRoot>/ai-artifacts/generated/<slug>/
# The final line is JSON with the visual-artifact-spec.json path.
shift 2 || true
exec pnpm extract:pipeline "$repo_root" "$slug" "$@"
