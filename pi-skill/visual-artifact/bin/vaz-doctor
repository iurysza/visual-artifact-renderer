#!/usr/bin/env bash
# Verify the visual-artifact global installation.
# Usage: vaz-doctor
set -e
source "${VAZ_SKILL_DIR:-$HOME/.pi/skills/visual-artifact}/lib/common.sh"

fail=0

echo "{\"check\": \"runtime\", \"path\": \"$VAZ_DIR\"}"
if [ -d "$VAZ_DIR" ]; then
  echo "{\"check\": \"runtime\", \"ok\": true}"
else
  echo "{\"check\": \"runtime\", \"ok\": false, \"error\": \"runtime not found\"}"
  fail=1
fi

echo "{\"check\": \"dependencies\", \"path\": \"$VAZ_DIR/node_modules\"}"
if [ -d "$VAZ_DIR/node_modules" ]; then
  echo "{\"check\": \"dependencies\", \"ok\": true}"
else
  echo "{\"check\": \"dependencies\", \"ok\": false, \"error\": \"dependencies not installed. Run: cd $VAZ_DIR && pnpm install\"}"
  fail=1
fi

echo "{\"check\": \"wrappers\"}"
for wrapper in vaz-doctor vaz-serve vaz-status vaz-pipeline; do
  if command_exists "$wrapper"; then
    echo "{\"check\": \"wrapper\", \"name\": \"$wrapper\", \"ok\": true}"
  elif [ -x "$VAZ_BIN_DIR/$wrapper" ]; then
    echo "{\"check\": \"wrapper\", \"name\": \"$wrapper\", \"ok\": true, \"note\": \"found at $VAZ_BIN_DIR/$wrapper but not in PATH\"}"
  else
    echo "{\"check\": \"wrapper\", \"name\": \"$wrapper\", \"ok\": false, \"error\": \"not in PATH or $VAZ_BIN_DIR\"}"
    fail=1
  fi
done

echo "{\"check\": \"pi-cli\"}"
if command_exists pi; then
  echo "{\"check\": \"pi-cli\", \"ok\": true}"
else
  echo "{\"check\": \"pi-cli\", \"ok\": false, \"error\": \"pi command not found in PATH\"}"
  fail=1
fi

echo "{\"check\": \"extractor-tools\"}"
for tool in depcruise knip sg jscpd; do
  if command_exists "$tool"; then
    echo "{\"check\": \"extractor-tool\", \"name\": \"$tool\", \"ok\": true}"
  else
    echo "{\"check\": \"extractor-tool\", \"name\": \"$tool\", \"ok\": false, \"warning\": \"tool missing; some extractors may fail\"}"
  fi
done

echo "{\"check\": \"server\", \"url\": \"$VAZ_SERVER_URL\"}"
if server_running; then
  echo "{\"check\": \"server\", \"ok\": true, \"url\": \"$VAZ_SERVER_URL\"}"
else
  echo "{\"check\": \"server\", \"ok\": false, \"error\": \"server not running. Run: vaz-serve\"}"
  fail=1
fi

if [ "$fail" -eq 0 ]; then
  echo "{\"status\": \"healthy\"}"
  exit 0
else
  echo "{\"status\": \"unhealthy\", \"fix\": \"Run install.sh from the visualizer repo or run $VAZ_SKILL_DIR/bootstrap.sh\"}"
  exit 1
fi
