#!/usr/bin/env bash
# Tailscale publishing helper for visual artifacts.
# Ensures the visualizer is reachable on the tailnet and returns shareable URLs.
#
# Usage:
#   vaz-tailscale status                 # JSON status of tailscale + renderer
#   vaz-tailscale url [project] [slug]   # print tailnet URL
#   vaz-tailscale setup                  # ensure tailscale serve proxies /artifacts/
set -e
source "${VAZ_SKILL_DIR:-$HOME/.pi/skills/visual-artifact}/lib/common.sh"

TA_PATH="/artifacts/"
BACKEND="http://127.0.0.1:9999/artifacts"

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

_get_tailscale_status_json() {
  tailscale status --json 2>/dev/null || true
}

_get_tailnet_dns() {
  local json="$1"
  if [ -z "$json" ]; then
    return
  fi
  if command_exists python3; then
    python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    dns = d.get('Self', {}).get('DNSName', '')
    print(dns.rstrip('.'))
except Exception:
    pass
" <<< "$json" 2>/dev/null || true
  elif command_exists node; then
    node -e "
let d = '';
try { d = require('fs').readFileSync(0, 'utf8'); } catch {}
try {
  const obj = JSON.parse(d);
  const dns = (obj.Self && obj.Self.DNSName) || '';
  console.log(dns.replace(/\.$/, ''));
} catch {}
" <<< "$json" 2>/dev/null || true
  fi
}

_get_serve_status() {
  tailscale serve status 2>/dev/null || true
}

_serve_route_configured() {
  local status="$1"
  [ -n "$status" ] && grep -qE -- '\|--+ /artifacts/[[:space:]]+proxy[[:space:]]+http://127\.0\.0\.1:9999/artifacts([[:space:]]|$)' <<< "$status"
}

_tailnet_base_url() {
  local dns="$1"
  if [ -n "$dns" ]; then
    echo "https://${dns}/artifacts"
  fi
}

cmd_status() {
  local ts_json ts_dns ts_serve server_ok route_ok tailnet_base

  server_ok=false
  if server_running; then
    server_ok=true
  fi

  ts_json=""
  ts_dns=""
  ts_serve=""
  route_ok=false

  if command_exists tailscale; then
    ts_json=$(_get_tailscale_status_json)
    ts_dns=$(_get_tailnet_dns "$ts_json")
    ts_serve=$(_get_serve_status)
    if _serve_route_configured "$ts_serve"; then
      route_ok=true
    fi
  fi

  tailnet_base=$(_tailnet_base_url "$ts_dns")

  printf '{%s}' "
  \"tailscaleInstalled\": $(command_exists tailscale && echo true || echo false),
  \"tailnetHost\": \"${ts_dns}\",
  \"tailnetBaseUrl\": \"${tailnet_base}\",
  \"serverRunning\": ${server_ok},
  \"serveRouteConfigured\": ${route_ok},
  \"serveStatus\": \"$(echo "$ts_serve" | sed 's/\\/\\\\/g; s/"/\\"/g; s/$/\\n/' | tr -d '\n' | sed 's/\\n$//')\"
"
}

cmd_url() {
  local project="$1"
  local slug="$2"
  local json dns base

  if ! command_exists tailscale; then
    echo "{\"error\": \"tailscale not installed\"}" >&2
    exit 1
  fi

  json=$(_get_tailscale_status_json)
  dns=$(_get_tailnet_dns "$json")

  if [ -z "$dns" ]; then
    echo "{\"error\": \"tailscale not running or DNS name unavailable\"}" >&2
    exit 1
  fi

  base=$(_tailnet_base_url "$dns")

  if [ -n "$project" ] && [ -n "$slug" ]; then
    echo "${base}/${project}/${slug}/"
  else
    echo "${base}/"
  fi
}

cmd_setup() {
  if ! command_exists tailscale; then
    echo "{\"error\": \"tailscale not installed\"}" >&2
    exit 1
  fi

  ensure_server

  local status
  status=$(_get_serve_status)

  if _serve_route_configured "$status"; then
    local dns base
    dns=$(_get_tailnet_dns "$(_get_tailscale_status_json)")
    base=$(_tailnet_base_url "$dns")
    echo "{\"ok\": true, \"action\": \"none\", \"tailnetBaseUrl\": \"${base}\", \"message\": \"Tailscale serve already proxies /artifacts/\"}"
    exit 0
  fi

  echo "[vaz-tailscale] Configuring tailscale serve for ${TA_PATH} -> ${BACKEND}..." >&2
  tailscale serve --yes --bg --https 443 --set-path "${TA_PATH}" "${BACKEND}"

  status=$(_get_serve_status)
  if _serve_route_configured "$status"; then
    local dns base
    dns=$(_get_tailnet_dns "$(_get_tailscale_status_json)")
    base=$(_tailnet_base_url "$dns")
    echo "{\"ok\": true, \"action\": \"configured\", \"tailnetBaseUrl\": \"${base}\", \"message\": \"Tailscale serve now proxies /artifacts/ to ${BACKEND}\"}"
  else
    echo "{\"ok\": false, \"error\": \"tailscale serve configuration failed\"}" >&2
    exit 1
  fi
}

case "${1:-status}" in
  status)
    cmd_status
    ;;
  url)
    cmd_url "$2" "$3"
    ;;
  setup)
    cmd_setup
    ;;
  -h|--help|help)
    echo "Usage: vaz-tailscale {status|url [project] [slug]|setup}"
    echo ""
    echo "Commands:"
    echo "  status                Show tailscale + renderer status as JSON."
    echo "  url [project] [slug]  Print the tailnet URL for artifacts or a specific artifact."
    echo "  setup                 Ensure tailscale serve proxies /artifacts/ to the renderer."
    ;;
  *)
    echo "Usage: vaz-tailscale {status|url [project] [slug]|setup}" >&2
    exit 1
    ;;
esac
