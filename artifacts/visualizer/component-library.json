          ] },
          { "title": "Render", "description": "The registry chooses a trusted adapter.", "nodes": [
            { "type": "text", "props": { "text": "Styling and behavior stay inside the renderer." } }
          ] }
        ]
      } },
      { "type": "knowledge-check", "props": {
        "prompt": "Which layer owns visual styling?",
        "choices": [
          { "id": "agent", "label": "The agent", "feedback": "The agent chooses meaning, not CSS." },
          { "id": "renderer", "label": "The renderer" }
        ],
        "answerId": "renderer",
        "explanation": "Trusted renderer components enforce consistent layout, behavior, and accessibility.",
        "hint": "Look for the layer that maps node types to components."
      } }
    ] },

