      "type": "diff",
      "props": {
        "title": "cache.go",
        "language": "go",
        "mode": "split",
        "indicators": "bars",
        "showLineNumbers": true,
        "before": "func Get(key string) (*Item, bool) {\n    if !exists {\n        return nil, false\n    }\n\n    now := time.Now()\n    expired := now.After(item.ExpiresAt)\n    if expired {\n        return nil, false\n    }\n\n    return item.Value, true\n}",
        "after": "func Get(key string) (*Item, bool) {\n    if !exists {\n        return nil, false\n    }\n\n    if time.Now().After(item.ExpiresAt) {\n        delete(c.items, key)\n        c.onEviction(key, item.Value)\n        return nil, false\n    }\n\n    return item.Value, true\n}"
      }
